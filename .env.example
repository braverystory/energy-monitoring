# Database Configuration (for Ubuntu/Linux use file:./prisma/dev.db)
DATABASE_URL="file:./prisma/dev.db"

# Authentication
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://139.59.248.103:3000"

# API Configuration
NEXT_PUBLIC_API_URL="http://139.59.248.103:3000/api"

# Energy Monitoring Settings
ENERGY_REFRESH_INTERVAL=5000
ALERT_CHECK_INTERVAL=30000

# Cost per kWh (in USD)
COST_PER_KWH=3

# MQTT Configuration
MQTT_BROKER_URL="mqtt://139.59.248.103:1883"
MQTT_TOPIC="energy/+/data"

# Alert Thresholds (percentage of capacity)
ALERT_WARNING_THRESHOLD=80
ALERT_CRITICAL_THRESHOLD=90

# Data Retention (in days)
DATA_RETENTION_DAYS=90

# Email Configuration (for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="energy-monitor@hospital.com"

# Environment
NODE_ENV="development"
